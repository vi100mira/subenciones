{
  "name": "subvenciones-rag",
  "private": true,
  "version": "0.2.7",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-build-info.mjs",
    "build:info": "node scripts/generate-build-info.mjs",
    "typecheck": "tsc --noEmit",
    "check:line-budgets": "node scripts/guardrails/check-line-budgets.mjs",
    "check:hosted-workers": "node scripts/guardrails/check-hosted-workers.mjs",
    "check:runtime-truth": "node scripts/guardrails/check-runtime-truth-ui.mjs",
    "check:tenant-plan-ui": "node scripts/guardrails/check-tenant-plan-ui.mjs",
    "check:project-docs": "node scripts/guardrails/check-project-documentation.mjs",
    "check:help-assistant": "node scripts/guardrails/check-help-assistant.mjs",
    "check:evidence": "node scripts/guardrails/check-source-evidence-fixtures.mjs && node scripts/guardrails/check-grant-source-authority.mjs && node scripts/guardrails/check-bdns-evidence-policy.mjs && node scripts/guardrails/check-supplementary-basis-sources.mjs && node scripts/guardrails/check-proposal-constraints.mjs && node scripts/guardrails/check-grant-requirements.mjs && node scripts/guardrails/check-document-requirement-classifier.mjs && node scripts/guardrails/check-openai-bases-provider.mjs && node scripts/guardrails/check-private-radar-gate.mjs && node scripts/guardrails/check-draft-agent-contract.mjs && node scripts/guardrails/check-openai-draft-provider.mjs && node scripts/guardrails/check-proposal-pdf.mjs && node scripts/guardrails/check-approved-draft-export.mjs && npm run platform:verify-source-evidence -- --today=2026-07-06",
    "check:ui": "node scripts/guardrails/check-opportunity-grid-ui.mjs && node scripts/guardrails/check-onboarding-ui.mjs",
    "check:platform-superadmin": "node scripts/guardrails/check-platform-superadmin-ui.mjs",
    "check:e2e:onboarding": "node scripts/guardrails/check-onboarding-e2e.mjs",
    "check:tenant-agents": "node scripts/guardrails/check-tenant-agent-registry.mjs",
    "check:entity-research": "node scripts/guardrails/check-entity-research-contract.mjs",
    "check:tenant-match": "node scripts/guardrails/check-tenant-match-contract.mjs",
    "check:document-review": "node scripts/guardrails/check-document-review-contract.mjs",
    "check:private-knowledge": "node scripts/guardrails/check-private-knowledge-flow.mjs",
    "check:private-source-preflight": "node scripts/guardrails/check-private-source-preflight.mjs",
    "check:private-analysis-history": "node scripts/guardrails/check-private-analysis-history.mjs",
    "check:local-private-inventory": "node scripts/guardrails/check-local-private-inventory-worker.mjs",
    "check:private-fact-retrieval": "node scripts/guardrails/check-private-fact-retrieval.mjs",
    "check:draft-version-ui": "node scripts/guardrails/check-draft-version-ui.mjs",
    "check:agent-execution-controls": "node scripts/guardrails/check-agent-execution-controls.mjs",
    "check:tenant-bases": "node scripts/guardrails/check-tenant-bases-acceptance.mjs",
    "check:draft-versions": "node scripts/guardrails/check-draft-document-versions.mjs",
    "check:private-corpus-docs": "node scripts/guardrails/check-private-corpus-document-builder.mjs",
    "check:stability": "npm run typecheck && npm run check:line-budgets && npm run check:hosted-workers && npm run check:runtime-truth && npm run check:project-docs && npm run check:help-assistant && npm run check:tenant-agents && npm run check:entity-research && npm run check:tenant-match && npm run check:document-review && npm run check:private-knowledge && npm run check:private-source-preflight && npm run check:private-analysis-history && npm run check:local-private-inventory && npm run check:private-fact-retrieval && npm run check:agent-execution-controls && npm run check:tenant-bases && npm run check:draft-versions && npm run check:private-corpus-docs && npm run check:evidence",
    "auth:seed-users": "node scripts/admin/upsert-auth-users.mjs",
    "auth:verify-users": "node scripts/admin/verify-auth-users.mjs",
    "tenant:verify-recovery": "node scripts/admin/verify-tenant-recovery.mjs",
    "radar:bdns": "node scripts/radar/fetch-bdns-latest.mjs",
    "radar:bdns:municipal": "node scripts/radar/fetch-bdns-latest.mjs --campaign=municipal-social --pages=2 --page-size=50 --max-details=300 --output-name=bdns-municipal-social.json --prototype-out=prototype/municipal-radar-data.js",
    "radar:bdns:municipal:bases": "node scripts/radar/prepare-bdns-bases-scan.mjs && node scripts/platform/deep-scan-open-funders.mjs --catalog=.tmp/bdns-bases-scan-catalog.json --write=data/public-radar/bdns-municipal-bases-scan.json && node scripts/radar/apply-bdns-bases-scan.mjs",
    "radar:audit-bases-coverage": "node scripts/radar/audit-bases-coverage.mjs",
    "radar:audit-document-plan": "node scripts/radar/audit-document-plan-readiness.mjs --manifest=scripts/radar/document-plan-audit-inputs.json --id-prefix=bdns-",
    "platform:import-bdns-radar": "node scripts/platform/import-bdns-radar.mjs",
    "platform:import-open-funders": "node scripts/platform/import-open-funders.mjs",
    "platform:deep-scan-open-funders": "node scripts/platform/deep-scan-open-funders.mjs",
    "platform:apply-open-funder-scan": "node scripts/platform/apply-open-funder-scan.mjs",
    "platform:verify-source-evidence": "node scripts/platform/verify-source-evidence-contract.mjs",
    "platform:detect-open-funder-changes": "node scripts/platform/detect-open-funder-changes.mjs",
    "platform:generate-tenant-alerts": "node scripts/platform/generate-tenant-change-alerts.mjs",
    "platform:run-alert-e2e": "node scripts/platform/run-alert-e2e.mjs",
    "platform:seed-demo-watch": "node scripts/platform/seed-demo-watch.mjs",
    "tenant:verify-approved-draft": "node scripts/guardrails/check-approved-draft-export.mjs",
    "worker:chunk-documents": "node scripts/workers/chunk-documents.mjs",
    "worker:local-private-inventory": "node scripts/workers/run-local-private-inventory.mjs",
    "worker:municipal-radar": "node scripts/workers/run-municipal-radar.mjs",
    "worker:general-radar": "node scripts/workers/run-municipal-radar.mjs --campaign=general-social",
    "worker:private-funder-radar": "node scripts/workers/run-private-funder-radar.mjs",
    "worker:draft-agent": "node scripts/workers/run-draft-agent.mjs",
    "deploy": "npx vercel deploy --prod --yes"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "@vercel/blob": "^2.3.3",
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "pdfkit": "^0.19.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.11.24",
    "@types/pdfkit": "^0.17.6",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^5.5.28",
    "typescript": "^5.2.2"
  }
}
